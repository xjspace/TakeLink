{
  "name": "takelink",
  "version": "1.1.0",
  "description": "TakeLink - 局域网远程终端，随时随地接管你的终端",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "takelink": "./bin/takelink.mjs"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "cap:init": "cap init 'TakeLink' com.takelink.app --web-dir public",
    "cap:add": "cap add android",
    "cap:sync": "cap sync android",
    "cap:build": "cap sync android && cap open android",
    "android:build": "pnpm run cap:sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor-community/barcode-scanner": "^4.0.1",
    "@xterm/addon-fit": "^0.11.0",
    "ansi-to-html": "^0.7.2",
    "chalk": "^5.3.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.7.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
