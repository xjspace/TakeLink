# TakeLink 配置文件示例
# 复制此文件为 .env 并修改配置

# 服务端口 (默认 8080)
PORT=8080

# 访问密码 (可选，为空则无需认证)
# 设置密码后，手机连接时需要输入密码才能访问
PASSWORD=

# tmux 会话持久化 (默认启用)
USE_TMUX=true

# 默认工作目录 (可选)
DEFAULT_CWD=

# Claude Code 启动命令
# Windows 默认: cmd.exe
# Linux/Mac 默认: /bin/bash
# CLAUDE_COMMAND=claude

# 自定义快捷命令 (显示在终端工具栏)
# 格式: 名称:命令,名称:命令
# CUSTOM_COMMANDS=Claude:claude,Git:git status
