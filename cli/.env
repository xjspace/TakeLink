# TakeLink 配置文件
# 复制此文件为 .env 并修改配置

# 服务端口 (默认 8080)
PORT=8080

# 访问密码 (可选，为空则无需认证)
# 设置密码后，手机连接时需要输入密码才能访问
PASSWORD=123465

# tmux 会话持久化 (默认启用)
# 启用后，即使浏览器关闭，终端会话仍会在后台运行
# 下次连接时可恢复到之前的状态
# 注意：仅 Linux/Mac 支持，Windows 自动禁用
USE_TMUX=true

# 默认工作目录 (可选)
# 启动终端时自动进入此目录
DEFAULT_CWD=

# Claude Code 启动命令
# Windows 默认: cmd.exe
# Linux/Mac 默认: /bin/bash
CLAUDE_COMMAND=g:\zhipu

# 自定义快捷命令 (显示在终端工具栏)
# 格式: 名称:命令,名称:命令
# 注意: Windows 路径要用双反斜杠 \\ 或正斜杠 /
CUSTOM_COMMANDS=Claude:g:\zhipu,Git:git status


