{
  "expo": {
    "name": "TakeLink",
    "slug": "takelink",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "takelink",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.takelink.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TakeLink 需要访问相机来扫描服务器二维码"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.takelink.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "TakeLink 需要访问相机来扫描服务器二维码"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
